{
  "headers": [
    {
      "source": "/academy/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/academy",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/admin/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/admin",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/academy/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/admin/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "functions": {
    "api/crm/bulk-upload.js": { "maxDuration": 300, "memory": 1024 },
    "api/crm/carousel-generator.js": { "maxDuration": 300 },
    "api/crm/bulk-agent.js": { "maxDuration": 300 },
    "api/crm/email-agent.js": { "maxDuration": 60 },
    "api/crm/global-agent.js": { "maxDuration": 60 },
    "api/crm/yt-research.js": { "maxDuration": 300, "memory": 1024 },
    "api/crm/yt-scripts.js": { "maxDuration": 120 },
    "api/crm/yt-thumbnails.js": { "maxDuration": 300 },
    "api/crm/yt-assets.js": { "maxDuration": 30 },
    "api/crm/content-ai.js": { "maxDuration": 60 },
    "api/crm/process-brand-bible.js": { "maxDuration": 60 },
    "api/academy/ai-generate.js": { "maxDuration": 60 },
    "api/academy/transcribe.js": { "maxDuration": 300, "memory": 1024 },
    "api/academy/billing.js": { "maxDuration": 30 },
    "api/academy/stripe-webhook.js": { "maxDuration": 30 }
  },
  "redirects": [
    { "source": "/book-call", "destination": "https://calendar.app.google/LayD3nk48Jy3uH95A", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/academy/assets/:path*", "destination": "/academy/assets/:path*" },
    { "source": "/academy/:path*", "destination": "/academy/index.html" },
    { "source": "/academy", "destination": "/academy/index.html" },
    { "source": "/admin/assets/:path*", "destination": "/admin/assets/:path*" },
    { "source": "/admin/:path*", "destination": "/admin/index.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/tutorials/:slug", "destination": "/post.html" },
    { "source": "/post", "destination": "/post.html" },
    { "source": "/creators", "destination": "/creators.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/portfolio/pickapaint", "destination": "/pickapaint.html" },
    { "source": "/portfolio", "destination": "/portfolio.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
