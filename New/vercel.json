{
  "functions": {
    "api/crm/content-ai.js": { "maxDuration": 60 },
    "api/crm/process-brand-bible.js": { "maxDuration": 60 }
  },
  "redirects": [
    { "source": "/book-call", "destination": "https://calendar.app.google/LayD3nk48Jy3uH95A", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/admin/assets/:path*", "destination": "/admin/assets/:path*" },
    { "source": "/admin/:path*", "destination": "/admin/index.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/tutorials/:slug", "destination": "/post.html" },
    { "source": "/post", "destination": "/post.html" },
    { "source": "/creators", "destination": "/creators.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/portfolio/pickapaint", "destination": "/pickapaint.html" },
    { "source": "/portfolio", "destination": "/portfolio.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
